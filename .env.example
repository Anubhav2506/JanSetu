# JanSetu environment variables
# Copy this file to .env and fill in real values.
# Never commit .env.

# Frontend Firebase web app config
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_optional

# Frontend Google Maps browser key
VITE_GOOGLE_MAPS_API_KEY=your_maps_javascript_api_key_here

# Firebase Functions base URL, for example:
# https://us-central1-your-project-id.cloudfunctions.net
VITE_FUNCTIONS_BASE_URL=your_functions_base_url_here

# Backend-only values for functions/.env
# GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_MAPS_API_KEY=your_backend_geocoding_key_here
